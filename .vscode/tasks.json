{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ng: serve",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Application bundle generation complete"
        }
      }
    },
    {
      "label": "func: start",
      "type": "shell",
      "command": "func start",
      "options": {
        "cwd": "${workspaceFolder}/frontend/api"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "For detailed output, run func with --verbose flag"
        }
      }
    },
    {
      "label": "full-stack: start",
      "dependsOn": ["ng: serve", "func: start"],
      "dependsOrder": "parallel"
    }
  ]
}
