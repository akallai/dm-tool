{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "swa: start",
      "type": "shell",
      "command": "source .env && swa start http://localhost:4200 --api-location ./api",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Azure Static Web Apps emulator started"
        }
      },
      "dependsOn": "ng: serve"
    },
    {
      "label": "ng: serve",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "message": 0
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Application bundle generation complete"
        }
      }
    }
  ]
}
